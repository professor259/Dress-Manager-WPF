<UserControl x:Class="Attendance.View.Home"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Attendance.View"
             Loaded="UserControl_Loaded"
              xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks" 
             xmlns:shared="http://schemas.actiprosoftware.com/winfx/xaml/shared"
              xmlns:vm="clr-namespace:Attendance.ViewModel"
             mc:Ignorable="d" 
            
            Background="#eff2f7"
              Style="{StaticResource Page_Style}"
             d:DesignHeight="1024"
              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" d:DesignWidth="768">
    <UserControl.DataContext>
        <vm:HomeVM />
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style x:Key="StandardButtons" TargetType="{x:Type Button}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border x:Name="LoginBorder" Background="{TemplateBinding Background}"
                                            CornerRadius="16">
                            <ContentPresenter HorizontalAlignment="Center" 
                                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="DarkRed" TargetName="LoginBorder"  />
                                <Setter Property="TextBlock.Foreground" Value="AliceBlue"  TargetName="LoginBorder" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="Gray" TargetName="LoginBorder"  />
                                <Setter Property="TextBlock.Foreground" Value="Black"  TargetName="LoginBorder" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Grid.Column="1" Margin="30 20 20 20">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>
        <Separator Height="1" Grid.Row="3" Background="#dae2ea" Margin="0 0 0 0" />
        <!--Tab Buttons-->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0 10 0 0">
            <Button IsEnabled="False" Name="ShowBtn" HorizontalAlignment="Center" Content="Dashboard" Style="{StaticResource tabButton}" BorderBrush="#FFFFC0C0" Width="748"/>
     
        </StackPanel>
        <Icon:PackIconMaterial Kind="ViewDashboard"  Width="15" Height="16" VerticalAlignment="Center" Margin="120,20,0,10" Foreground="Black" HorizontalAlignment="Center" Grid.Row="2"/>
        <Grid Width="200" Height="100" HorizontalAlignment="Left" Grid.Row="4" Margin="30 100 0 0" MouseDown="Grid_MouseDown">
            <Border Background="DarkOrchid" CornerRadius="15" />
            <TextBlock x:Name="TotalDress" Margin="20 25 25 0" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Total Dresses"/>
            <Icon:PackIconMaterial Kind="Hanger" Width="30" Height="30" VerticalAlignment="Center" Margin="20,36,0,34" Foreground="#ffffff" HorizontalAlignment="Left"/>

        </Grid>
        <Grid Width="200" Height="100" HorizontalAlignment="Center" Grid.Row="4" Margin="0 100 0 0" MouseDown="Grid_MouseDown">
            <Border Background="CornflowerBlue" CornerRadius="15" />
            <TextBlock x:Name="TotalReservation" Margin="20 25 25 0" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Total Reservation"/>
            <Icon:PackIconMaterial Kind="ArrowDecision" Width="30" Height="30" VerticalAlignment="Center" Margin="20 0 0 0" Foreground="#ffffff" HorizontalAlignment="Left"/>

        </Grid>
        <Grid Width="200" Height="100" HorizontalAlignment="Right" Grid.Row="4" Margin="0 100 30 0"  >
        <Border Background="LightSalmon" CornerRadius="15"/>
            <TextBlock x:Name="ActiveReserve" Margin="20 25 25 0" FontWeight="Regular" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Active Reservation"/>
            <Icon:PackIconMaterial Kind="Spa" Width="30" Height="30" VerticalAlignment="Center" Margin="20,37,0,33" Foreground="#ffffff" HorizontalAlignment="Left"/>
        </Grid>
        <Grid Width="200" Height="100" HorizontalAlignment="Right" Grid.Row="4" Margin="0 100 30 -250"  >
            <Border Background="#978181" CornerRadius="15"/>
            <TextBlock x:Name="TotalPuchases" Margin="20 25 25 0" FontWeight="Regular" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Total Purchases"/>
            <Icon:PackIconMaterial Kind="AccountCash" Width="30" Height="30" VerticalAlignment="Center" Margin="20,37,0,33" Foreground="#ffffff" HorizontalAlignment="Left"/>
        </Grid>
        <Grid Width="200" Height="100" HorizontalAlignment="Left" Grid.Row="4" Margin="30 100 30 -250"  >
            <Border Background="SlateGray" CornerRadius="15"/>
            <TextBlock x:Name="TotalPurchase" Margin="20 25 25 0" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Delivered"/>
            <Icon:PackIconMaterial Kind="HandCoin" Width="30" Height="30" VerticalAlignment="Center" Margin="20 0 0 0" Foreground="#ffffff" HorizontalAlignment="Left"/>
        </Grid>
        <Grid Width="200" Height="100" HorizontalAlignment="Center" Grid.Row="4" Margin="0 100 0 -250"  >
            <Border Background="#388e3c" CornerRadius="15"/>
            <TextBlock x:Name="CompeletedReservation" Margin="20 25 25 0" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Center"  Foreground="#ffffff" IsHitTestVisible="False" Panel.ZIndex="1" Text="0"/>
            <TextBlock Margin="15 15" FontWeight="Regular" FontFamily="SemiBold" FontSize="15" HorizontalAlignment="Center" VerticalAlignment="Top"  Foreground="#FFECECEA" IsHitTestVisible="False" Panel.ZIndex="1" Text="Completed Reservation"/>
            <Icon:PackIconMaterial Kind="CheckCircle" Width="30" Height="30" VerticalAlignment="Center" Margin="20,39,0,31" Foreground="#ffffff" HorizontalAlignment="Left"/>
        </Grid>
    </Grid>
</UserControl>
