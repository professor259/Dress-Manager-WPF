<UserControl x:Class="Attendance.View.Admins"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
                xmlns:Menu="clr-namespace:Attendance.Utilities"
              xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"     
             xmlns:local="clr-namespace:Attendance.View"      
             xmlns:shared="http://schemas.actiprosoftware.com/winfx/xaml/shared"
              xmlns:vm="clr-namespace:Attendance.ViewModel"
             mc:Ignorable="d" 
             Background="#eff2f7"
             Loaded="UserControl_Loaded"
              Style="{StaticResource Page_Style}"
             d:DesignHeight="1024"
              xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml" d:DesignWidth="768">
    <UserControl.DataContext>
        <vm:AdminsVM />
    </UserControl.DataContext>
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBoxBase}">
                        <Border x:Name="border" CornerRadius="12" Padding="10 7" Background="#ffffff" BorderBrush="#e0e6ed" BorderThickness="1">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#d9d9d9" TargetName="border"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#d9d9d9" TargetName="border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>

    <Grid >


        <!--Main Section-->
        <Grid Grid.Column="1" Margin="30 20 20 20">
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="auto"/>
            </Grid.RowDefinitions>

            <Separator Height="1" Grid.Row="1" Background="#dae2ea" Margin="0,56.498,0,37.498"/>
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="-15,-3,-15,3">
                <Button IsEnabled="False" Name="ShowBtn" HorizontalAlignment="Center" Content="Admins Managment" Style="{StaticResource tabButton}" BorderBrush="#FFFFC0C0" Width="748" Margin="0,13.998,0,35.998"/>

            </StackPanel>
            <!--Add Admin-->
            <Button Margin="0,62,10,38.287" Click="Button_Click" Style="{StaticResource addButton}" Grid.RowSpan="4">
                <StackPanel Orientation="Horizontal">
                    <Icon:PackIconMaterial Kind="Plus" VerticalAlignment="Center" Width="11" Height="11" Margin="0 1 8 0"/>
                    <TextBlock Text="Add Admin"/>
                </StackPanel>
            </Button>

            <!--Seperator-->

            <!--Tab Buttons-->

            <!--Filter-->
            <TextBlock Text="Filter by:" Grid.Row="4" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="383.593,19.5,283.593,3.5"/>
            <ComboBox x:Name="FilterTypes"  IsEditable="False" FontSize="13" FontWeight="SemiBold" IsReadOnly="True" HorizontalAlignment="Right" VerticalAlignment="Center"  SelectionChanged="FilterTypes_SelectionChanged" SelectedIndex="0" Grid.Row="4"  Width="64.18" Margin="0 20 210 0"  Height="27.29"  >
                <ComboBoxItem  Content="Name"/>
                <ComboBoxItem  Content="ID"/>
            </ComboBox>
            <Grid Width="200" HorizontalAlignment="Right" Grid.Row="4" >
                <TextBlock Margin="15,23.165,15,1.165" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Search here ...." Visibility="{Binding ElementName=txtFilter,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                <TextBox x:Name="txtFilter"   Padding="35 15"  TextChanged="TxtFilter_TextChanged" Margin="0,12,0,-12"  />
                <Icon:PackIconMaterial Kind="Magnify" Width="15" Height="15" VerticalAlignment="Center" Margin="0,24.645,15,0.645" Foreground="#b0b9c6" HorizontalAlignment="Right"/>
            </Grid>

            <!--DataGrid-->
            <DataGrid Grid.Row="5" ItemsSource="{Binding Items}"  x:Name="memberDatagrid" RowStyle="{DynamicResource DataGridRowStyle1}" ColumnHeaderStyle="{DynamicResource DataGridColumnHeaderStyle1}" CellStyle="{DynamicResource DataGridCellStyle1}" Style="{DynamicResource DataGridStyle1}" Margin="0,16,0,54.29" Grid.RowSpan="2">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" IsReadOnly="True" CanUserResize="False" Width="auto" Binding="{ Binding Path=Index}"/>
                    <DataGridTemplateColumn Header="Name" IsReadOnly="True" CanUserResize="False" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="25" Height="25" CornerRadius="50" Margin="0 0 10 0" Background="{Binding Path=ColorBg}">
                                        <TextBlock Text="{Binding Path=Charater}" VerticalAlignment="Center" Width="auto" HorizontalAlignment="Center" Foreground="White" Margin="0 0 0 1"/>
                                    </Border>
                                    <TextBlock Text="{Binding Path=Name}" Width="auto"  VerticalAlignment="Center"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="ID" IsReadOnly="True"  CanUserResize="False" Width="auto"  Binding="{ Binding Path=ID}"/>
                    <DataGridTextColumn Header="Username" IsReadOnly="True"  CanUserResize="False" Width="*"  Binding="{ Binding Path=Username}"/>
                    <DataGridTextColumn Header="Password" IsReadOnly="True"  CanUserResize="False" Width="*"  Binding="{ Binding Path=Password}"/>
                    <DataGridTextColumn Header="State" IsReadOnly="True"  CanUserResize="False" Width="*"  Binding="{ Binding Path=StateView}"/>
                    <DataGridTextColumn Header="Email" Binding="{Binding Path=Email}" IsReadOnly="True" Width="*"/>
                    <DataGridTextColumn Header="Phone" Binding="{Binding Path=Phone}" IsReadOnly="True" Width="*"/>
                    <DataGridTemplateColumn Header="Operations" IsReadOnly="True" CanUserResize="False" Width="auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <Button x:Name="EditBtn" Click="EditBtn_Click" Style="{StaticResource gridEditButton}">
                                        <Icon:PackIconMaterial Kind="PencilOutline" Style="{StaticResource gridButtonIcon}"/>
                                    </Button>
                                    <Button x:Name="DeleteBtn" Style="{StaticResource gridDeleteButton}" Click="DeleteBtn_Click"  Margin="5 0 0 0">
                                        <Icon:PackIconMaterial Kind="DeleteOutline" Style="{StaticResource gridButtonIcon}"/>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
            <Border Grid.Row="6" HorizontalAlignment="Right" BorderBrush="#dee4ec" BorderThickness="1" CornerRadius="5" Padding="5" Background="White" Margin="0 10 10 10">
                <StackPanel Orientation="Horizontal">
                    <Rectangle Width="1" Fill="#dee4ec"  Margin="3 7"/>
                    <Button x:Name="FirstPage" Click="FirstPage_Click"  Style="{StaticResource pagingButton}">
                        <Icon:PackIconMaterial Kind="ChevronDoubleLeft" Style="{StaticResource pagingButtonIcon}"/>
                    </Button>
                    <Button x:Name="PrevPage" Click="PrevPage_Click"  Style="{StaticResource pagingButton}">
                        <Icon:PackIconMaterial Kind="ChevronLeft" Style="{StaticResource pagingButtonIcon}"/>
                    </Button>
                    <Rectangle Width="1" Fill="#dee4ec"  Margin="3 7"/>
                    <Menu:Btn x:Name="Page1" Click="Page1_Click" Style="{StaticResource pagingButtons}" Content="1" IsChecked="True" ></Menu:Btn>
                    <Menu:Btn x:Name="Page2" Click="Page2_Click" Style="{StaticResource pagingButtons}" Content="2" ></Menu:Btn>
                    <Menu:Btn x:Name="Page3" Click="Page3_Click" Style="{StaticResource pagingButtons}" Content="3" ></Menu:Btn>
                    <Rectangle Width="1" Fill="#dee4ec"  Margin="3 7"/>
                    <Button x:Name="NextPage" Click="NextPage_Click"  Style="{StaticResource pagingButton}">
                        <Icon:PackIconMaterial Kind="ChevronRight" Style="{StaticResource pagingButtonIcon}"/>
                    </Button>

                    <Button x:Name="LastPage" Click="LastPage_Click"  Style="{StaticResource pagingButton}">
                        <Icon:PackIconMaterial Kind="ChevronDoubleRight" Style="{StaticResource pagingButtonIcon}"/>
                    </Button>
                    <Rectangle Width="1" Fill="#dee4ec"  Margin="3 7"/>
                </StackPanel>
            </Border>

        </Grid>


    </Grid>

</UserControl>
