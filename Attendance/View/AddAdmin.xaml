<UserControl x:Class="Attendance.View.AddAdmin"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Attendance.View"
              xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"  
             mc:Ignorable="d" 
             Background="Transparent"             
           
                 Style="{StaticResource Page_Style}"
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TextBoxBase}">
                        <Border x:Name="border" CornerRadius="12" Padding="10 7" Background="#ffffff" BorderBrush="#e0e6ed" BorderThickness="1">
                            <ScrollViewer Margin="0" x:Name="PART_ContentHost" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="BorderBrush" Value="#d9d9d9" TargetName="border"/>
                            </Trigger>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#d9d9d9" TargetName="border"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    </UserControl.Resources>
    <Border Background="#FFBABBBB" CornerRadius="30" >
        <Grid>


            <Grid Grid.Column="1" Margin="30 20 20 20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Separator Height="1" Grid.Row="3" Background="#dae2ea" Margin="0 -1 0 10"/>
                <!--Tab Buttons-->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0 10 0 0">
                    <Button Name="ShowBtn" Content="Add New Admin" Style="{StaticResource tabButton}" BorderBrush="#FFFFC0C0" Width="748"/>
                </StackPanel>
                <Icon:PackIconMaterial Kind="Account" Width="15" Height="16" VerticalAlignment="Center" Margin="440,20,0,10" Foreground="Black" HorizontalAlignment="Left" Grid.Row="2"/>
                <TextBlock Text="Username:" Grid.Row="4" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0 0 215 0"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="89,8,-59,8" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Username ...." Visibility="{Binding ElementName=Username,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="Username"   Padding="35 15"  Margin="74,0,-74,0"  />

                </Grid>
                <TextBlock Text="Password:" Grid.Row="5" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,34,0,262"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="89,67,-59,-51" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Password ...." Visibility="{Binding ElementName=Password,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="Password"   Padding="35 15"   Margin="74,58,-74,-58" HorizontalAlignment="Left" Width="200"  />

                </Grid>
                <TextBlock Text="Phone:" Grid.Row="5" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,84,0,213"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="89,117,-59,-101" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Phone ...." Visibility="{Binding ElementName=Phone,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="Phone" PreviewTextInput="NumberValidationTextBox"  Padding="35 15"   Margin="74,109,-74,-109"  />

                </Grid>
                <TextBlock Text="Email:" Grid.Row="5" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,140,0,156"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="89,173,-59,-157" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Email ...." Visibility="{Binding ElementName=Email,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="Email"   Padding="35 15"   Margin="74,165,-74,-165"  />

                </Grid>
                <TextBlock Text="FullName:" Grid.Row="5" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,189,0,107"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="89,221,-59,-205" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Admin Name ...." Visibility="{Binding ElementName=FullName,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="FullName"   Padding="35 15"   Margin="74,214,-74,-214"  />

                </Grid>
                <TextBlock Text="Admin ID:" Grid.Row="4" FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="425,10,0,4"/>
                <Grid Width="200" HorizontalAlignment="Left" Grid.Row="4" >
                    <TextBlock Margin="521,10,-491,6" VerticalAlignment="Center" Foreground="#b0b9c6" IsHitTestVisible="False" Panel.ZIndex="1" Text="Enter Admin ID ...." Visibility="{Binding ElementName=AdminID,Path=Text.IsEmpty,Converter={StaticResource BoolToVis}}"/>
                    <TextBox x:Name="AdminID"  PreviewTextInput="NumberValidationTextBox" Padding="35 15"  Margin="503,2,-503,-2"  />

                </Grid>
                <TextBlock Text="Admin Level:"  FontSize="13" FontWeight="SemiBold" Foreground="#121518" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,34,249,261" Grid.Row="5"/>
                <ComboBox x:Name="AdminSelect"  IsEditable="False" FontSize="13" FontWeight="SemiBold" IsReadOnly="True" HorizontalAlignment="Left" VerticalAlignment="Center"  Text="Select Admin"   Width="135" Margin="527,30,0,256"  Height="27" Grid.Row="5"  >
                    <ComboBoxItem Content="Member"></ComboBoxItem>
                    <ComboBoxItem Content="Admin"></ComboBoxItem>
                </ComboBox>
                <Button x:Name="AddBtn" Style="{StaticResource addButton}" Click="Button_Click" Margin="0,256,434,22" Grid.Row="5">
                    <StackPanel Orientation="Horizontal">
                        <Icon:PackIconMaterial Kind="Plus"  VerticalAlignment="Center" Width="11" Height="11" Margin="0 1 8 0"/>
                        <TextBlock Text="Add Admin"/>
                    </StackPanel>
                </Button>
                <Button x:Name="Cancel" Style="{StaticResource addButton}" Background="#d32f2f" Click="Cancel_Click"  Margin="0,256,175,22" Grid.Row="5">
                    <StackPanel Orientation="Horizontal">
                        <Icon:PackIconMaterial Kind="Cancel"  VerticalAlignment="Center" Width="11" Height="11" Margin="0 1 8 0"/>
                        <TextBlock Text="Cancel"/>
                    </StackPanel>
                </Button>

            </Grid>
        </Grid>
    </Border>
</UserControl>
