<Window x:Class="Attendance.WPF.GUI"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
       xmlns:Icon="http://metro.mahapps.com/winfx/xaml/iconpacks"               
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
          xmlns:vm="clr-namespace:Attendance.ViewModel"
         xmlns:Menu="clr-namespace:Attendance.Utilities"
        xmlns:li="clr-namespace:Attendance.LoadingSpinnerControl"
        xmlns:local="clr-namespace:Attendance"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        AllowsTransparency="True"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"      
        Background="Transparent"
        Title="Attendance System" Height="720" Width="1080">
    <Window.DataContext>
        <vm:NavigationVM />
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    </Window.Resources>

    <Border Background="#eff2f7" CornerRadius="30" MouseDown="Border_MouseDown" MouseLeftButtonDown="Border_MouseLeftButtonDown" >
        <Grid>



            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="200"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!--Left Menu-->
            <Grid>

                <Grid.RowDefinitions>

                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Button Style="{StaticResource topButton}" Margin="20 28 0 35">
                    <Icon:PackIconMaterial Kind="Menu" Width="15" Height="15"/>
                </Button>
                <Border Grid.Row="1" CornerRadius="29 50 0 29" Background="#FFD03E3E">
                    <DockPanel>
                        <Border DockPanel.Dock="Top"
            Height="168"
            Background="Transparent"
            HorizontalAlignment="Center"
            Margin="18,10">
                            <Viewbox Stretch="Uniform" Margin="0,0,0,35">
                                <Image Source="pack://application:,,,/Images/logo.png"
                   SnapsToDevicePixels="True"
                   UseLayoutRounding="True"
                   RenderOptions.BitmapScalingMode="HighQuality" Height="1242" Width="1335"/>
                            </Viewbox>
                        </Border>



                        <Separator Margin="15" DockPanel.Dock="Top" Height="0.8" Background="#FFFFC0C0"/>
                        <StackPanel DockPanel.Dock="Top">
                            <Menu:Btn Style="{StaticResource navButton}" IsChecked="True" Command="{Binding HomeCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="HomeVariant"  Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Dashboard">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                           
                            <Menu:Btn x:Name="DressBtn" Style="{StaticResource navButton}" Command="{Binding FacultyCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Hanger" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Dress Manager">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="StudentsButton" Style="{StaticResource navButton}"  Command="{Binding StudentsCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="AccountMultipleOutline" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Reservation">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="MaterialBtn" Style="{StaticResource navButton}"  Command="{Binding MaterialCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="MaterialUi" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Queues">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="ClassButton" Style="{StaticResource navButton}"  Command="{Binding ClassCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="CashMinus" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Purchases">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="ReportBtn" Style="{StaticResource navButton}"  Command="{Binding AttendanceCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="ChartLine" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Reports">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="SearchBtn" Style="{StaticResource navButton}"  Command="{Binding SearchCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="SearchWeb" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Search">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="SettingBtn" Style="{StaticResource navButton}"  Command="{Binding SettingsCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="Cog" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Settings">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                            <Menu:Btn x:Name="AdminBtn" Style="{StaticResource navButton}"  Command="{Binding AdminsCommand}" >
                                <StackPanel Orientation="Horizontal">
                                    <Icon:PackIconMaterial Kind="AccountEdit" Style="{StaticResource menuButtonIcon}"/>
                                    <TextBlock Text="Admins">

                                    </TextBlock>
                                </StackPanel>
                            </Menu:Btn>
                        </StackPanel>
                        <Button Style="{StaticResource menuButton}" Click="Button_Click" VerticalAlignment="Bottom" DockPanel.Dock="Bottom" Margin="15 0 15 20" >
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="LocationExit" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Exit">

                                </TextBlock>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource menuButton}"  Click="Btn_Click"  VerticalAlignment="Bottom" DockPanel.Dock="Bottom" Margin="15 0 15 20" >
                            <StackPanel Orientation="Horizontal">
                                <Icon:PackIconMaterial Kind="Logout" Style="{StaticResource menuButtonIcon}"/>
                                <TextBlock Text="Log out">

                                </TextBlock>
                            </StackPanel>
                        </Button>
                      
                    </DockPanel>
                </Border>
            </Grid>


            <Grid Grid.Column="1" Margin="0,0,50,0">
                <ContentControl x:Name="Pages"
                                Content="{Binding CurrentView}" Margin="0,0,0,0" />
            </Grid>
        </Grid>
    </Border>
</Window>